# CurricuLLM-AU — OpenAI-compatible key (powers all content generation + meme humour LLM)
CURRICULLM_API_KEY=
# Optional: override the model used by CurricuLLM (defaults to gpt-4o-mini)
CURRICULLM_MODEL=gpt-5.4-mini

# fal.ai — image generation (currently unused, kept for future use)
FAL_API_KEY=

# Database (Turso)
TURSO_DATABASE_URL=https://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Auth
RESEND_API_KEY=re_your_resend_key
JWT_SECRET=your-generated-secret-min-32-chars

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cogniti mini app URLs
# NEXT_PUBLIC_COGNITI_MINIAPP_URL=
# NEXT_PUBLIC_COGNITI_CONCEPTMAP_URL=
