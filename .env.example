# CurricuLLM-AU — OpenAI-compatible key (powers all content generation + meme humour LLM)
CURRICULLM_API_KEY=
# Optional: override the model used by CurricuLLM (defaults to gpt-4o-mini)
# CURRICULLM_MODEL=gpt-4o-mini

# fal.ai — image generation (currently unused, kept for future use)
FAL_API_KEY=

# Database (Turso)
TURSO_DATABASE_URL=https://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Auth
RESEND_API_KEY=re_your_resend_key
JWT_SECRET=your-generated-secret-min-32-chars

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Video Upload (hidden upload page for Anusha)
# Set this in Vercel env vars. Share the URL: /upload-video?key=<value>
UPLOAD_VIDEO_KEY=your-secret-upload-key-here

# Cogniti mini app URLs
# NEXT_PUBLIC_COGNITI_MINIAPP_URL=
# NEXT_PUBLIC_COGNITI_CONCEPTMAP_URL=

# ─── Observability ───────────────────────────────────────────────────────────

# PostHog — product analytics + session replay (free tier: 1M events/month)
# Project ID: 369383 (US Cloud) — credentials in 1Password: OpenClaw-Agents → "PostHog QuestLearn — questlearn"
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=<see 1Password: OpenClaw-Agents → PostHog QuestLearn — questlearn>
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry — error tracking + performance monitoring (already wired via @sentry/nextjs)
# Project: questlearn-nextjs (org: redditech)
# DSN + auth token stored in 1Password: OpenClaw-Agents → "Sentry QuestLearn — questlearn-nextjs"
# Auth token stored in 1Password: OpenClaw → "Sentry API Credentials"
NEXT_PUBLIC_SENTRY_DSN=<see 1Password: OpenClaw-Agents → Sentry QuestLearn — questlearn-nextjs>
SENTRY_AUTH_TOKEN=<see 1Password: OpenClaw → Sentry API Credentials>
SENTRY_ORG=redditech
SENTRY_PROJECT=questlearn-nextjs
# Vercel Log Drain (add in Vercel project settings → Log Drains):
# https://o4507542820290560.ingest.us.sentry.io/api/4511150024753152/integration/vercel/logs

# Langfuse — LLM observability + prompt management (free tier: 5k traces/month)
# US Cloud region — credentials in 1Password: OpenClaw-Agents → "Langfuse QuestLearn — questlearn"
LANGFUSE_SECRET_KEY=<see 1Password: OpenClaw-Agents → Langfuse QuestLearn — questlearn>
LANGFUSE_PUBLIC_KEY=<see 1Password: OpenClaw-Agents → Langfuse QuestLearn — questlearn>
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
